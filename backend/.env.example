# Scalpel — Multimodal Hackathon backend environment

# --- LLM: Nebius Token Factory (default) or MiniMax / Bedrock ---
LLM_PROVIDER=nebius          # nebius | minimax | bedrock

# MiniMax (OpenAI-compatible) — https://api.minimax.io/v1
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_LLM_MODEL=MiniMax-M2.1
MINIMAX_MODEL_LOGGER=
MINIMAX_MODEL_ANSWER=
MINIMAX_MODEL_INTRO=
MINIMAX_MODEL_SUMMARY=

# Nebius — set LLM_PROVIDER=nebius when ready
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_MODEL_DEFAULT=meta-llama/Meta-Llama-3.1-70B-Instruct
NEBIUS_MODEL_LOGGER=
NEBIUS_MODEL_ANSWER=
NEBIUS_MODEL_INTRO=
NEBIUS_MODEL_SUMMARY=

# --- Voice: Vapi ---
VAPI_PUBLIC_KEY=
VAPI_PRIVATE_KEY=
VAPI_OR_ASSISTANT_ID=
VAPI_INTRO_ASSISTANT_ID=
# Deepgram model via Vapi — nova-3-medical recommended for OR/clinical speech
VAPI_TRANSCRIBER_MODEL=nova-3-medical
# Turn-taking — Deepgram endpointing ms (default 10 is too aggressive; 500+ for OR pauses)
VAPI_TRANSCRIBER_ENDPOINTING_MS=500
VAPI_ENDPOINT_NO_PUNCT_SEC=2.8
VAPI_ENDPOINT_PUNCT_SEC=0.35
VAPI_ENDPOINT_NUMBER_SEC=1.2
VAPI_START_WAIT_SEC=0.5
VAPI_STOP_NUM_WORDS=3
VAPI_STOP_VOICE_SEC=0.35
VAPI_STOP_BACKOFF_SEC=1.2
# Spoken clinical answers — lines/chars before TTS truncation
SPOKEN_MAX_LINES=3
SPOKEN_MAX_CHARS=360
# Nebius gates whether voice speech should mark the OR checklist (1=on)
VOICE_CHECKLIST_LLM=1
VAPI_SERVER_URL=

# --- Storage: Insforge (filesystem fallback when unset) ---
STORAGE_BACKEND=filesystem
INSFORGE_PROJECT_ID=         # npx @insforge/cli link --project-id <uuid>
INSFORGE_URL=                # e.g. https://<appkey>.<region>.insforge.app
INSFORGE_ANON_KEY=
INSFORGE_SERVICE_KEY=        # from .insforge/project.json after link; server-side only

# --- API ---
SCALPEL_API_PORT=3001
CORS_ORIGINS=*
HIPAA_MODE=false
INSFORGE_UI_ORIGIN=
CASE_DATA_DIR=

# --- Optional retrieval / ingestion ---
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
TAVILY_API_KEY=
UNSILOED_API_KEY=

# Optional Bedrock fallback (only if LLM_PROVIDER=bedrock) ---
# AWS_BEDROCK_REGION=us-east-1
# BEDROCK_AWS_ACCESS_KEY_ID=
# BEDROCK_AWS_SECRET_ACCESS_KEY=
